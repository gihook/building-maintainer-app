@page
@model BuildingMaintainerWebApp.Pages.HistoryModel
@{
    ViewData["Title"] = "Istorija zamena";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        h1 {
            text-align: center;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }
        th {
            background-color: #f2f2f2;
        }
        /* Mobile specific styles */
        @@media (max-width: 600px) {
            table, thead, tbody, th, td, tr {
                display: block;
            }
            thead tr {
                position: absolute;
                top: -9999px;
                left: -9999px;
            }
            tr {
                margin-bottom: 15px;
            }
            td {
                border: none;
                border-bottom: 1px solid #eee;
                position: relative;
                padding-left: 50%;
            }
            td:before {
                position: absolute;
                top: 6px;
                left: 6px;
                width: 45%;
                padding-right: 10px;
                white-space: nowrap;
                font-weight: bold;
            }
            td:nth-of-type(1):before { content: "Stanar"; }
            td:nth-of-type(2):before { content: "Broj potrosenih kesa"; }
            td:nth-of-type(3):before { content: "Datum"; }
        }
    </style>
</head>
<body>
    <h1>Istorija zamena</h1>

    <table>
        <thead>
            <tr>
                <th>Stanar</th>
                <th>Broj potrosenih kesa</th>
                <th>Datum</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.History)
            {
                <tr>
                    <td>@item.Stanar</td>
                    <td>@item.BrojPotrosenihKesa</td>
                    <td>@item.Datum</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
