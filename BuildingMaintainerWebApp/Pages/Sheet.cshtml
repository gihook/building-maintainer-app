@page "/sheet/{sheetName}"
@model BuildingMaintainerWebApp.Pages.SheetModel
@{
    ViewData["Title"] = Model.SheetName;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        h1 {
            text-align: center;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }
        th {
            background-color: #f2f2f2;
        }
        /* Mobile specific styles */
        @@media (max-width: 600px) {
            table, thead, tbody, th, td, tr {
                display: block;
            }
            thead tr {
                position: absolute;
                top: -9999px;
                left: -9999px;
            }
            tr {
                margin-bottom: 15px;
            }
            td {
                border: none;
                border-bottom: 1px solid #eee;
                position: relative;
                padding-left: 50%;
            }
            td:before {
                position: absolute;
                top: 6px;
                left: 6px;
                width: 45%;
                padding-right: 10px;
                white-space: nowrap;
                font-weight: bold;
                content: attr(data-label);
            }
        }
    </style>
</head>
<body>
    <h1>@Model.SheetName</h1>

    @if (Model.SheetData.Any())
    {
        <table>
            <thead>
                <tr>
                    @foreach (var header in Model.Headers)
                    {
                        <th>@header</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.SheetData)
                {
                    <tr>
                        @foreach (var header in Model.Headers)
                        {
                            <td data-label="@header">@row.GetValueOrDefault(header)</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No data found in this sheet.</p>
    }
</body>
</html>
