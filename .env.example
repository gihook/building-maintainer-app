# --- Docker Configuration ---
WEB_PORT=8080
WAHA_PORT=3000
WAHA_API_URL=http://waha:3000
WAHA_LOG_LEVEL=info

# --- ASP.NET Core Configuration ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_HTTP_PORTS=8080

# --- Building Maintainer Configuration ---
# Note: Variables below can be mapped in appsettings.json or via environment variables
# as MaintainerConfig__CredentialsPath, etc. (using double underscore for nesting)

MAINTAINER_CONFIG__CREDENTIALS_PATH=/app/credentials.json
MAINTAINER_CONFIG__SPREADSHEET_ID=your_spreadsheet_id_here
MAINTAINER_CONFIG__RANGE_EMAILS=Stanari!C2:C100
MAINTAINER_CONFIG__RANGE_REPLACER=Glavna!A5:B5
MAINTAINER_CONFIG__RANGE_HISTORY=Istorija zamena!A2:C100
MAINTAINER_CONFIG__SENDER_NAME="Okrugiceva 24"
MAINTAINER_CONFIG__SENDER_EMAIL=your_email@example.com
MAINTAINER_CONFIG__SMTP_SERVER=smtp.gmail.com
MAINTAINER_CONFIG__SMTP_PORT=587
MAINTAINER_CONFIG__SMTP_USER=your_smtp_username
MAINTAINER_CONFIG__SMTP_PASS=your_smtp_password
